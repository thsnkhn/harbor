    "error.torrent.duplicateDestination" : {
      "comment" : "Friendly torrent error shown when the target file already exists. Parameter is the existing file path.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "An item with this name already exists in the destination. Harbor stopped the torrent to avoid overwriting or truncating it.\n\nExisting item:\n%1$@\n\nMove, rename, or delete the existing item, then retry the download."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un elemento con questo nome esiste già nella destinazione. Harbor ha interrotto il torrent per evitare di sovrascriverlo o troncarlo.\n\nElemento esistente:\n%1$@\n\nSposta, rinomina o elimina l'elemento esistente, quindi riprova il download."
          }
        }
      }
    },
