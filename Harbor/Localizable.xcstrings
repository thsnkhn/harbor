    "error.torrent.duplicateDestination" : {
      "comment" : "Friendly torrent error shown when the target file already exists. Parameter is the existing file path.",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "An item with this name already exists in the destination. Harbor stopped the torrent to avoid overwriting or truncating it.\n\nExisting item:\n%@\n\nMove, rename, or delete the existing item, then retry the download."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya existe un elemento con este nombre en el destino. Harbor detuvo el torrent para evitar sobrescribirlo o truncarlo.\n\nElemento existente:\n%1$@\n\nMueve, renombra o elimina el elemento existente y vuelve a intentar la descarga."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un elemento con questo nome esiste già nella destinazione. Harbor ha interrotto il torrent per evitare di sovrascriverlo o troncarlo.\n\nElemento esistente:\n%@\n\nSposta, rinomina o elimina l'elemento esistente, quindi riprova il download."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "目标位置中已存在同名项目。Harbor 已停止该任务，以避免覆盖或截断现有文件。\n\n现有项目：\n%@\n\n请移动、重命名或删除现有项目，然后重试下载。\n"
          }
        }
      }
    },
